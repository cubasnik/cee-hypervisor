# App
APP_NAME=CEE Hypervisor
DEBUG=False
VERSION=2.0.0

# Security
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Database
DATABASE_URL=postgresql://cee:cee123@localhost:5432/cee

# Libvirt
LIBVIRT_URI=qemu:///system

# Storage
IMAGES_PATH=/var/lib/libvirt/images
MAX_IMAGE_SIZE=53687091200  # 50GB in bytes
